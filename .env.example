# === Database ===
# Get connection string from Neon Console: https://console.neon.tech
TREADSTONE_DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# === App ===
TREADSTONE_APP_NAME=treadstone
TREADSTONE_DEBUG=false
# Public web-app origin used for browser auth (OAuth callbacks, sandbox bootstrap, CLI browser login).
# Local ingress default. If you run `make dev` directly without ingress, use http://localhost:8000 instead.
# Prod: https://app.treadstone-ai.dev (frontend nginx proxies /v1/ to the backend)
TREADSTONE_APP_BASE_URL=http://localhost
TREADSTONE_AUTH_TYPE=cookie
TREADSTONE_SESSION_TTL_SECONDS=604800

# === Auth Secrets ===
TREADSTONE_JWT_SECRET=CHANGE_ME_IN_PROD

# === OAuth Social (leave empty to disable) ===
# Register these callback URLs with each provider (must match TREADSTONE_APP_BASE_URL):
#   Local ingress: http://localhost/v1/auth/google/callback and http://localhost/v1/auth/github/callback
#   Local `make dev`: http://localhost:8000/v1/auth/google/callback and http://localhost:8000/v1/auth/github/callback
#   Demo: https://app-demo.treadstone-ai.dev/v1/auth/google/callback and https://app-demo.treadstone-ai.dev/v1/auth/github/callback
#   Prod: https://app.treadstone-ai.dev/v1/auth/google/callback and https://app.treadstone-ai.dev/v1/auth/github/callback
TREADSTONE_GOOGLE_OAUTH_CLIENT_ID=
TREADSTONE_GOOGLE_OAUTH_CLIENT_SECRET=
TREADSTONE_GITHUB_OAUTH_CLIENT_ID=
TREADSTONE_GITHUB_OAUTH_CLIENT_SECRET=

# === Auth0 / Authing / Logto (leave empty to disable) ===
TREADSTONE_AUTH0_DOMAIN=
TREADSTONE_AUTH0_CLIENT_ID=
TREADSTONE_AUTHING_DOMAIN=
TREADSTONE_AUTHING_APP_ID=
TREADSTONE_LOGTO_DOMAIN=
TREADSTONE_LOGTO_APP_ID=

# === CORS (Web UI) ===
# Comma-separated or JSON list of allowed origins for the frontend.
# Default (for make dev + make dev-web): ["http://localhost:5173"]
# Prod example: ["https://app.treadstone-ai.dev"]
TREADSTONE_CORS_ALLOWED_ORIGINS=["http://localhost:5173"]

# === Sandbox ===
# Subdomain-based sandbox routing (for browser Web UI access)
# Dev: "sandbox.localhost"  ->  {sandbox_id}.sandbox.localhost
# Prod: "sandbox.example.com"  ->  {sandbox_id}.sandbox.example.com
# Empty string disables subdomain routing.
TREADSTONE_SANDBOX_DOMAIN=
# Required when TREADSTONE_SANDBOX_DOMAIN is public/non-local:
# TREADSTONE_APP_BASE_URL must be set to the public app origin.
# Must match the K8s namespace for this environment (treadstone-local / treadstone-demo / treadstone-prod)
TREADSTONE_SANDBOX_NAMESPACE=treadstone-local
TREADSTONE_SANDBOX_PORT=8080
TREADSTONE_SANDBOX_PROXY_TIMEOUT=180.0
TREADSTONE_SANDBOX_STORAGE_CLASS=treadstone-workspace
TREADSTONE_SANDBOX_DEFAULT_STORAGE_SIZE=5Gi
TREADSTONE_SANDBOX_SUBDOMAIN_PREFIX=sandbox-

# === Email Verification ===
# Backend for sending verification emails: "memory" (dev/test) or "resend" (production)
TREADSTONE_EMAIL_BACKEND=memory
# Required when TREADSTONE_EMAIL_BACKEND=resend. Get your API key at https://resend.com
TREADSTONE_RESEND_API_KEY=
# Sender address shown in verification emails
TREADSTONE_EMAIL_FROM=noreply@treadstone-ai.dev
# How long the email verification link stays valid, in seconds (default: 1 hour)
TREADSTONE_VERIFICATION_TOKEN_LIFETIME_SECONDS=3600

# === Metering ===
# When true, quota checks are enforced on API requests. When false, usage is still recorded but limits are not enforced.
TREADSTONE_METERING_ENFORCEMENT_ENABLED=true

# === Leader Election ===
# Enable this in K8s environment files such as .env.local / .env.demo / .env.prod
# so only one pod runs Watch + Reconciliation. Keep it false for bare local `make dev`.
TREADSTONE_LEADER_ELECTION_ENABLED=false
TREADSTONE_LEADER_ELECTION_LEASE_NAME=treadstone-sync-leader
TREADSTONE_LEADER_ELECTION_LEASE_DURATION_SECONDS=15
TREADSTONE_LEADER_ELECTION_RENEW_INTERVAL_SECONDS=5
TREADSTONE_LEADER_ELECTION_RETRY_INTERVAL_SECONDS=2

# === Kubernetes pod identity (optional; injected by deploy/treadstone when running in-cluster) ===
TREADSTONE_POD_NAME=
TREADSTONE_POD_NAMESPACE=
